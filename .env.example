# PostgreSQL
POSTGRES_USER=wright_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=project_wright
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=changeme
MONGO_URI=mongodb://root:changeme@localhost:27017
MONGO_DB=project_wright


# Redis
REDIS_URL=redis://localhost:6379/0

# FastAPI
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Pipeline mode — controls which model profile is used across all agents
# Values: "local" or "cloud"
PIPELINE_MODE=local

# --- LOCAL MODEL PROFILE ---
LOCAL_MODEL=qwen3.5:4b

# --- CLOUD MODEL PROFILE (uncomment when PIPELINE_MODE=cloud in Week 7) ---
# CLOUD_MODEL_IDC=qwen3-next:80b-cloud
# CLOUD_MODEL_SB=qwen3-coder-next-cloud
# CLOUD_MODEL_RP=deepseek-v3.2-cloud
# CLOUD_MODEL_OS=qwen3-next:80b-cloud
# CLOUD_MODEL_DF=qwen3.5:122b-cloud
# CLOUD_MODEL_CH=kimi-k2-thinking-cloud
# CLOUD_MODEL_BR=nemotron-3-nano:30b-cloud

ALEMBIC_DATABASE_URL=postgresql+asyncpg://wright_user:changeme@localhost:5432/project_wright


# App runtime — ADD in Phase 2, Week 3
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
